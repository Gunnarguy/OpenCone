//
//  Release.xcconfig
//  OpenCone
//

// Configuration settings file format documentation:
// https://help.apple.com/xcode/\#/dev745c5c974

// MARK: - Build Settings
GCC_PREPROCESSOR_DEFINITIONS = NDEBUG=1
OTHER_SWIFT_FLAGS = -DNDEBUG

// MARK: - Optimization (full optimization for release)
SWIFT_OPTIMIZATION_LEVEL = -Owholemodule

// MARK: - Code Signing
// Set your team ID in Xcode project settings, not here

// MARK: - Swift Compiler
SWIFT_STRICT_CONCURRENCY = complete

// MARK: - Sanitizers (all disabled for release)
ENABLE_ADDRESS_SANITIZER = NO
ENABLE_THREAD_SANITIZER = NO
ENABLE_UNDEFINED_BEHAVIOR_SANITIZER = NO
