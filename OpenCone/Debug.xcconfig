//
//  Debug.xcconfig
//  OpenCone
//

// Configuration settings file format documentation:
// https://help.apple.com/xcode/\#/dev745c5c974

// MARK: - Build Settings
GCC_PREPROCESSOR_DEFINITIONS = DEBUG=1
OTHER_SWIFT_FLAGS = -DDEBUG

// MARK: - Optimization (disabled for debug)
SWIFT_OPTIMIZATION_LEVEL = -Onone

// MARK: - Code Signing
// Set your team ID in Xcode project settings, not here

// MARK: - Swift Compiler
SWIFT_STRICT_CONCURRENCY = complete

// MARK: - Sanitizers (enable one at a time)
// ENABLE_ADDRESS_SANITIZER = YES
// ENABLE_THREAD_SANITIZER = YES
ENABLE_UNDEFINED_BEHAVIOR_SANITIZER = YES
